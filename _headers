/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.youtube.com https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://images.pexels.com https://*.pexels.com; frame-src https://www.youtube.com https://www.openstreetmap.org; connect-src 'self' https://api.web3forms.com https://api.github.com; base-uri 'self'; form-action 'self' https://api.web3forms.com https://formsubmit.co mailto:;

/admin.html
  X-Robots-Tag: noindex, nofollow, noarchive

/shared.js
  Cache-Control: no-cache, no-store, must-revalidate
/content.json
  Cache-Control: no-cache, no-store, must-revalidate
/*.html
  Cache-Control: no-cache
/assets/videos/*
  Cache-Control: public, max-age=3600

